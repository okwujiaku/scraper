# Option C — one worker per paying customer (copy to .env locally, never commit .env)

CLIENT_INDEX=1
DISCORD_TOKEN=customer_discord_user_token
CHAT_ID_CLIENT_1=customer_group_chat_id
# For client 2 on a second worker: CLIENT_INDEX=2, TOKEN_CLIENT_2, CHAT_ID_CLIENT_2

# Optional
CLIENT_NAME=Customer Name
SEND_STARTUP_PING=true
POLL_SECONDS=45
POLL_LIMIT=5
MAX_LOG_CHANNELS=120
# DEBUG_JOIN_LOGS=true
